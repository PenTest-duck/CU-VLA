# CU-VLA local config — copy to .env (gitignored) and fill in your values.
#
# These are loaded by scripts/launch_sm_job.py at startup via python-dotenv.
# Existing shell env vars take precedence over this file (so CI overrides
# still win).
#
# WANDB_API_KEY and HF_TOKEN are NOT in this file — they live in AWS SSM
# Parameter Store at /cu-vla/wandb-api-key and /cu-vla/hf-token, pulled by
# the in-container entrypoint via the IAM execution role. See
# docs/ops/aws-bootstrap.md §4.

# IAM role ARN for SageMakerExecutionRole-CU-VLA. Get it with:
#   aws iam get-role --role-name SageMakerExecutionRole-CU-VLA --query Role.Arn --output text
CU_VLA_SM_ROLE_ARN=arn:aws:iam::<your-account-id>:role/SageMakerExecutionRole-CU-VLA

# S3 bucket for in-flight spot checkpoints + job tarballs. Conventionally:
#   cu-vla-sm-<your-account-id>
CU_VLA_SM_BUCKET=cu-vla-sm-<your-account-id>

# AWS region for SageMaker (training jobs, S3 bucket, SSM Parameter Store, IAM
# role trust). Must match where the bootstrap resources actually live.
# Defaults to us-west-2 (where g6e.xlarge has the largest spot pool).
# Set this explicitly if your AWS profile default region is different —
# the launchers need it on every API call to avoid ResourceLimitExceeded
# in regions where g6e.xlarge isn't available.
CU_VLA_SM_REGION=us-west-2
